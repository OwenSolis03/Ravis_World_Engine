.PHONY : src/main.i

# target to preprocess a source file
src/main.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\RavisWorldEngine.dir\build.make CMakeFiles/RavisWorldEngine.dir/src/main.cpp.i
.PHONY : src/main.cpp.i

src/main.s: src/main.cpp.s
.PHONY : src/main.s

# target to generate assembly for a file
src/main.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\RavisWorldEngine.dir\build.make CMakeFiles/RavisWorldEngine.dir/src/main.cpp.s
.PHONY : src/main.cpp.s

